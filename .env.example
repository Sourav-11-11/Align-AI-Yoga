# ============================================================================
# Align AI Yoga - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NOTE: NEVER commit the actual .env file to git!

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# DB_TYPE can be 'sqlite' (default, for development and production on Render)
# or 'mysql' (requires MySQL server running locally or remote)
DB_TYPE=sqlite

# SQLite Database Path (used when DB_TYPE=sqlite)
# Default: align_yoga.db in the frontend directory
# Leave empty to use default
SQLITE_DB_PATH=

# MySQL Configuration (used when DB_TYPE=mysql)
# Leave these empty if using SQLite
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_PORT=3306
DB_NAME=yoga

# Optional: API Keys for future integrations
# GROQ_API_KEY=your_api_key_here

