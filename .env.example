# ============================================================================
# Align AI Yoga - Environment Configuration Template
# ============================================================================
# Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit the actual .env file to git!

# ─── Flask Configuration ─────────────────────────────────────────────────
# FLASK_ENV: 'development' (debug on) or 'production' (debug off)
FLASK_ENV=development

# SECRET_KEY: Used for session encryption. Generate a strong random key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string-in-production

# ─── Database Configuration ──────────────────────────────────────────────
# DB_TYPE: 'sqlite' (default, recommended) or 'mysql' (for scaling)
DB_TYPE=sqlite

# SQLite Database Path (used when DB_TYPE=sqlite)
# Leave empty to use default location: frontend/align_yoga.db
SQLITE_DB_PATH=

# ─── MySQL Configuration (used when DB_TYPE=mysql) ─────────────────────
# Only needed if using MySQL. Use SQLite for development.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_PORT=3306
DB_NAME=yoga

# ─── Optional: AI/API Integrations ────────────────────────────────────
# GROQ_API_KEY=your_api_key_for_chatbot_feature

