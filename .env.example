# ============================================================================
# Align AI Yoga - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NOTE: NEVER commit the actual .env file to git!

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database - PostgreSQL (Neon)
# Get your DATABASE_URL from https://neon.tech/
# Format for local: postgresql://user:password@localhost:5432/align_yoga_dev
# Format for Render: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/align_yoga_dev

# Optional: API Keys for future integrations
# GROQ_API_KEY=your_api_key_here
