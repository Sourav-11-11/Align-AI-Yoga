# ─────────────────────────────────────────────────────────────────────────
# CSP Align AI Yoga - Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────
#
# IMPORTANT: This file is a template. Copy this to .env and fill in your
# actual values. NEVER commit the actual .env file to version control.
# The .env file is already listed in .gitignore for protection.
#
# ─────────────────────────────────────────────────────────────────────────

# ── Flask Configuration ────────────────────────────────────────────────────

# Secret key for session management and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=your_secret_key_here_generate_with_python_secrets

# Flask environment: 'development' or 'production'
FLASK_ENV=development

# ── Groq API Configuration (for AI recommendations) ─────────────────────────

# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── MySQL Database Configuration ───────────────────────────────────────────

# Database host (typically 'localhost' for local development)
DB_HOST=localhost

# Database user (typically 'root' for local MySQL)
DB_USER=root

# Database password (your MySQL root or user password)
DB_PASSWORD=your_database_password

# Database port (typically 3306 for MySQL)
DB_PORT=3306

# Database name
DB_NAME=yoga

# ─────────────────────────────────────────────────────────────────────────
# Security Notes
# ─────────────────────────────────────────────────────────────────────────
#
# 1. NEVER hardcode secrets in source files.
# 2. NEVER commit .env to version control (it's in .gitignore).
# 3. For production, use a secure secrets manager (AWS Secrets Manager,
#    HashiCorp Vault, etc.) instead of .env files.
# 4. Rotate API keys regularly.
# 5. Use strong database passwords (min 12 chars, mixed case, numbers, symbols).
