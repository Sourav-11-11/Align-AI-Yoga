# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Virtual environment
venv/
env/

# Environment variables — never commit secrets
.env
*.env

# Logs
*.log

# ML model weights (large binary files)
*.pt
*.weights
*.h5
*.onnx
*.cfg

# Generated / uploaded images — store only the .gitkeep placeholder
FRONT END/static/saved_images/*
!FRONT END/static/saved_images/.gitkeep

# Pose reference image dataset (large, not source code)
FRONT END/data/
FRONT END/static/img/

# OS metadata
.DS_Store
Thumbs.db

# VS Code workspace settings
.vscode/

# Build artifacts
dist/
build/